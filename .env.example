# Visitors' book (optional). Without these, the guest book falls back to
# per-browser localStorage. With them, entries are shared via Supabase.
# See src/api/guestbook.ts for the one-time table + policy setup SQL.
# The anon key is public and safe to expose in the client.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
